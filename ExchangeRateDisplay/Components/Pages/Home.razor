@page "/"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient http
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Rates</PageTitle>

@if (rates == null)
{
    <p><em>Уншиж байна...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Валют</th>
                <th>Валютын нэр</th>
                <th>Ханш</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rate in rates)
            {
                <tr>
                    <td>@rate.Code</td>
                    <td>@CurrencyName(rate.Code)</td>
                    <td>@rate.Rate.ToString("0.00")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CurrencyRate>? rates;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        rates = await http.GetFromJsonAsync<List<CurrencyRate>>(
            "http://10.38.59.186:5062/CurrencyRates"
        );

        hubConnection = new HubConnectionBuilder()
            .WithUrl("http://10.38.59.186:5062/currencyRateHub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<CurrencyRate>("CurrencyRateUpdated", updatedRate =>
        {
            var existing = rates?.FirstOrDefault(x => x.Code == updatedRate.Code);

            if (existing == null)
            {
                rates?.Add(updatedRate);
            }
            else
            {
                existing.Rate = updatedRate.Rate;
            }

            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    public record CurrencyRate
    {
        public string Code { get; set; } = "";
        public double Rate { get; set; }
    }

    private string CurrencyName(string code)
    {
        return code switch
        {
            "USD" => "АМЕРИК ДОЛЛАР",
            "EUR" => "EВРО",
            "JPY" => "ЯПОНЫ ИЕН",
            "CHF" => "ШВЕЙЦАР ФРАНК",
            "GBP" => "АНГЛИЙН ФУНТ",
            "HKD" => "ГОНКОНГ ДОЛЛАР",
            "CNY" => "ХЯТАДЫН ЮАНЬ",
            "KRW" => "БНСУ-ЫН ВОН",
            "CAD" => "КАНАД ДОЛЛАР",
            "AUD" => "АВСТРАЛИ ДОЛЛАР",
            "SGD" => "СИНГАПУР ДОЛЛАР",
            "NZD" => "ШИНЭ ЗЕЛАНД ДОЛЛАР",
            _ => code
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
            await hubConnection.DisposeAsync();
    }
}